    {
        "id": "b22067a8a81bbd94",
        "type": "function",
        "z": "792ae5b2f20bb202",
        "g": "6beef9b705494822",
        "name": "flow.set('lastSpeed1'",
        "func": "// msg.payload = speed (0-max)\nvar speed = Number(msg.payload);\n\n// Save last non-zero speed (>1)\nif (speed > 1) {\n    flow.set('lastSpeed1', speed);\n}\n\n// Update switch state (>1 = ON)\nflow.set('switchState1', speed > 1 ? \"ON\" : \"OFF\");\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
